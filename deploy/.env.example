MYSQL_DATABASE=gift_chat
MYSQL_USER=gift_chat
MYSQL_PASSWORD=change-this-db-password
MYSQL_ROOT_PASSWORD=change-this-root-password

APP_AUTH_JWT_SECRET=replace-with-a-long-random-secret
APP_AUTH_ACCESS_TOKEN_MINUTES=720
APP_CORS_ALLOWED_ORIGINS=https://your-domain.com,http://your-server-ip
APP_UPLOAD_PUBLIC_BASE_URL=https://your-domain.com
APP_REALTIME_REDIS_ENABLED=true
APP_REALTIME_REDIS_CHANNEL=gift-chat:realtime
APP_TENCENT_CHAT_ENABLED=false
APP_TENCENT_CHAT_SDK_APP_ID=
APP_TENCENT_CHAT_SECRET_KEY=
APP_TENCENT_CHAT_ADMIN_IDENTIFIER=administrator
APP_TENCENT_CHAT_ADMIN_USER_SIG=

PUBLIC_HTTP_PORT=80
